# SMTP (ex.: HostGator, Office 365, etc.)
SMTP_HOST=mail.seudominio.com.br
SMTP_PORT=587
SMTP_USER=contato@seudominio.com.br
SMTP_PASS=sua_senha_aqui
SMTP_FROM=contato@seudominio.com.br

# Proposta: destino principal + cópias (CC), separados por vírgula
PROPOSTA_DESTINO=contato@seudominio.com.br
PROPOSTA_CC=usuario1@seudominio.com.br,usuario2@seudominio.com.br

PORT=3000
NODE_ENV=production

# Site público
SITE_URL=https://www.seudominio.com.br
CONTACT_PHONE=(11) 99999-9999
CONTACT_EMAIL=contato@seudominio.com.br

# Logo nos e-mails: por padrão usa IMG/logo-adaptavel.png embutido no envio.
# EMAIL_LOGO_URL=https://www.seudominio.com.br/IMG/logo-adaptavel.png
